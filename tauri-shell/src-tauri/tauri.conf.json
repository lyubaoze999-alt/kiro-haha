{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kiro-haha",
  "version": "0.1.0",
  "identifier": "com.lvbaoze.kiro-haha",
  "build": {
    "frontendDist": "../cchaha-dist"
  },
  "app": {
    "windows": [
      {
        "title": "kiro-haha",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "sidecar": false,
      "scope": [
        {
          "name": "kiro-cli",
          "cmd": "kiro-cli",
          "args": true
        }
      ]
    }
  }
}
